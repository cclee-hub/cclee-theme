# WordPress core files (keep themes for version control)
wp/wordpress/wp-admin/
wp/wordpress/wp-includes/
wp/wordpress/wp-*.php
wp/wordpress/xmlrpc.php
wp/wordpress/index.php
wp/wordpress/wp-content/plugins/*
!wp/wordpress/wp-content/plugins/cclee-toolkit/
wp/wordpress/wp-content/uploads/
wp/wordpress/wp-content/upgrade/
wp/wordpress/wp-content/backup/

# PbootCMS runtime (auto-generated)
cn-site/runtime/

# PbootCMS data copies
cn-site/data/*副本*

# Database backups
cn-site/static/backup/sql/

# Windows Zone files
*:Zone.Identifier

# Claude Code (keep rules, ignore sensitive)
.claude/credentials.md
.claude/*.log
.claude/handover.md
.claude/memory/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Additional WordPress files
wp/wordpress/.htaccess
wp/wordpress/license.txt
wp/wordpress/readme.html
wp/wordpress/wp-content/languages/
wp/wordpress/wp-content/index.php
wp/wordpress/wp-content/*/index.php
