{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Ocean",
	"description": "蓝绿色调，适合商务与企业站点",
	"settings": {
		"color": {
			"palette": [
				{ "slug": "primary", "color": "#1a365d", "name": "Primary" },
				{ "slug": "secondary", "color": "#4a5568", "name": "Secondary" },
				{ "slug": "accent", "color": "#0d9488", "name": "Accent" },
				{ "slug": "base", "color": "#ffffff", "name": "Base" },
				{ "slug": "contrast", "color": "#e6fffa", "name": "Contrast" }
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--primary)"
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--wp--preset--color--accent)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--primary)"
					}
				}
			}
		}
	}
}
