{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Warm",
	"description": "暖色调，适合创意与个人站点",
	"settings": {
		"color": {
			"palette": [
				{ "slug": "primary", "color": "#3d2914", "name": "Primary" },
				{ "slug": "secondary", "color": "#6b5344", "name": "Secondary" },
				{ "slug": "accent", "color": "#b45309", "name": "Accent" },
				{ "slug": "base", "color": "#fef7ed", "name": "Base" },
				{ "slug": "contrast", "color": "#fef3c7", "name": "Contrast" }
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--primary)"
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--wp--preset--color--accent)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--primary)"
					}
				}
			}
		}
	}
}
