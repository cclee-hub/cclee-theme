              "src": ["https://fonts.gstatic.com/s/spacegrotesk/v22/V8mQoQDjQSkFtoMM3T6r8E7mF71Q-gOoraIAEj42Vksj.ttf"]
            },
            {
              "fontFamily": "Space Grotesk",
              "fontStyle": "normal",
