{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "custom": {
      "breakpoints": {
        "mobile": "640px",
        "tablet": "768px",
        "desktop": "1024px",
        "wide": "1280px"
      },
      "border": {
        "radius": {
          "sm": "4px",
          "md": "8px",
          "lg": "12px",
          "full": "9999px"
        }
      },
      "shadow": {
        "sm": "0 1px 2px 0 rgb(0 0 0 / 0.05)",
        "md": "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)",
        "lg": "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)"
      }
    },
    "layout": {
      "contentSize": "800px",
      "wideSize": "1200px"
    },
    "color": {
      "palette": [
        { "slug": "primary",   "color": "#1a1a1a", "name": "Primary" },
        { "slug": "secondary", "color": "#4a4a4a", "name": "Secondary" },
        { "slug": "accent",    "color": "#0073aa", "name": "Accent" },
        { "slug": "base",      "color": "#ffffff", "name": "Base" },
        { "slug": "contrast",  "color": "#f5f5f5", "name": "Contrast" },
        { "slug": "neutral-50",  "color": "#fafafa", "name": "Neutral 50" },
        { "slug": "neutral-100", "color": "#f5f5f5", "name": "Neutral 100" },
        { "slug": "neutral-200", "color": "#e5e5e5", "name": "Neutral 200" },
        { "slug": "neutral-300", "color": "#d4d4d4", "name": "Neutral 300" },
        { "slug": "neutral-400", "color": "#a3a3a3", "name": "Neutral 400" },
        { "slug": "neutral-500", "color": "#737373", "name": "Neutral 500" },
        { "slug": "neutral-600", "color": "#525252", "name": "Neutral 600" },
        { "slug": "neutral-700", "color": "#404040", "name": "Neutral 700" },
        { "slug": "neutral-800", "color": "#262626", "name": "Neutral 800" },
        { "slug": "neutral-900", "color": "#171717", "name": "Neutral 900" }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "slug": "system",
          "name": "System Font",
          "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen-Sans, Ubuntu, Cantarell, 'Helvetica Neue', sans-serif"
        },
        {
          "slug": "mono",
          "name": "Monospace",
          "fontFamily": "Menlo, Monaco, Consolas, 'Courier New', monospace"
        }
      ],
      "fontSizes": [
        { "slug": "small",    "size": "0.875rem", "name": "Small"    },
        { "slug": "medium",   "size": "1rem",     "name": "Medium"   },
        { "slug": "large",    "size": "1.25rem",  "name": "Large"    },
        { "slug": "x-large",  "size": "1.5rem",   "name": "X Large"  },
        { "slug": "xx-large", "size": "2rem",     "name": "XX Large" },
        { "slug": "h1", "size": "2.5rem",   "name": "H1" },
        { "slug": "h2", "size": "2rem",     "name": "H2" },
        { "slug": "h3", "size": "1.5rem",   "name": "H3" },
        { "slug": "h4", "size": "1.25rem",  "name": "H4" },
        { "slug": "h5", "size": "1.125rem", "name": "H5" },
        { "slug": "h6", "size": "1rem",     "name": "H6" }
      ],
      "lineHeight": true
    },
    "spacing": {
      "spacingScale": {
        "operator": "*",
        "increment": 1.5,
        "steps": 7,
        "mediumStep": 1.5,
        "unit": "rem"
      },
      "spacingSizes": [
        { "slug": "10", "size": "0.25rem", "name": "1" },
        { "slug": "20", "size": "0.5rem",  "name": "2" },
        { "slug": "30", "size": "0.75rem", "name": "3" },
        { "slug": "40", "size": "1rem",    "name": "4" },
        { "slug": "50", "size": "1.5rem",  "name": "5" },
        { "slug": "60", "size": "2rem",    "name": "6" },
        { "slug": "70", "size": "3rem",    "name": "7" },
        { "slug": "80", "size": "4rem",    "name": "8" },
        { "slug": "90", "size": "6rem",    "name": "9" },
        { "slug": "100","size": "8rem",    "name": "10" }
      ],
      "units": [ "%", "px", "em", "rem", "vh", "vw" ],
      "padding": true,
      "margin": true
    },
    "border": {
      "radius": true,
      "color": true,
      "style": true,
      "width": true
    },
    "shadow": {
      "presets": [
        { "slug": "sm", "shadow": "0 1px 2px 0 rgb(0 0 0 / 0.05)" },
        { "slug": "md", "shadow": "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)" },
        { "slug": "lg", "shadow": "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)" }
      ]
    },
    "blocks": {
      "core/button": {
        "color": {
          "background": true,
          "text": true
        },
        "border": {
          "radius": true
        }
      },
      "core/image": {
        "border": {
          "radius": true
        }
      },
      "core/quote": {
        "border": {
          "color": true,
          "radius": true,
          "style": true,
          "width": true
        }
      }
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--base)",
      "text": "var(--wp--preset--color--primary)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--system)",
      "fontSize": "var(--wp--preset--font-size--medium)",
      "lineHeight": "1.6"
    },
    "spacing": {
      "blockGap": "var(--wp--preset--spacing--50)"
    },
    "elements": {
      "link": {
        "color": {
          "text": "var(--wp--preset--color--accent)"
        },
        "typography": {
          "textDecoration": "none"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--primary)"
          },
          "typography": {
            "textDecoration": "underline"
          }
        },
        ":focus": {
          "typography": {
            "textDecoration": "underline dotted"
          }
        }
      },
      "h1": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--h1)",
          "fontWeight": "700",
          "lineHeight": "1.2"
        },
        "spacing": {
          "margin": { "top": "0", "bottom": "var(--wp--preset--spacing--50)" }
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--h2)",
          "fontWeight": "700",
          "lineHeight": "1.3"
        },
        "spacing": {
          "margin": { "top": "0", "bottom": "var(--wp--preset--spacing--40)" }
        }
      },
      "h3": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--h3)",
          "fontWeight": "600",
          "lineHeight": "1.3"
        },
        "spacing": {
          "margin": { "top": "0", "bottom": "var(--wp--preset--spacing--40)" }
        }
      },
      "h4": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--h4)",
          "fontWeight": "600",
          "lineHeight": "1.4"
        },
        "spacing": {
          "margin": { "top": "0", "bottom": "var(--wp--preset--spacing--30)" }
        }
      },
      "h5": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--h5)",
          "fontWeight": "600",
          "lineHeight": "1.4"
        },
        "spacing": {
          "margin": { "top": "0", "bottom": "var(--wp--preset--spacing--30)" }
        }
      },
      "h6": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--h6)",
          "fontWeight": "600",
          "lineHeight": "1.5"
        },
        "spacing": {
          "margin": { "top": "0", "bottom": "var(--wp--preset--spacing--30)" }
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--base)"
        },
        "typography": {
          "fontWeight": "600"
        },
        "border": {
          "radius": "var(--wp--custom--border--radius--md)"
        },
        "spacing": {
          "padding": {
            "top": "var(--wp--preset--spacing--30)",
            "right": "var(--wp--preset--spacing--50)",
            "bottom": "var(--wp--preset--spacing--30)",
            "left": "var(--wp--preset--spacing--50)"
          }
        },
        ":hover": {
          "color": {
            "background": "var(--wp--preset--color--secondary)"
          }
        }
      },
      "caption": {
        "color": {
          "text": "var(--wp--preset--color--neutral-500)"
        },
        "typography": {
          "fontSize": "var(--wp--preset--font-size--small)"
        }
      },
      "cite": {
        "typography": {
          "fontStyle": "normal",
          "fontWeight": "500"
        }
      }
    },
    "blocks": {
      "core/quote": {
        "border": {
          "color": "var(--wp--preset--color--neutral-300)",
          "style": "solid",
          "width": "0 0 0 4px"
        },
        "spacing": {
          "padding": {
            "left": "var(--wp--preset--spacing--50)"
          }
        },
        "typography": {
          "fontStyle": "italic"
        }
      },
      "core/code": {
        "color": {
          "background": "var(--wp--preset--color--neutral-100)",
          "text": "var(--wp--preset--color--neutral-800)"
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--mono)",
          "fontSize": "var(--wp--preset--font-size--small)"
        },
        "spacing": {
          "padding": {
            "top": "var(--wp--preset--spacing--40)",
            "right": "var(--wp--preset--spacing--40)",
            "bottom": "var(--wp--preset--spacing--40)",
            "left": "var(--wp--preset--spacing--40)"
          }
        },
        "border": {
          "radius": "var(--wp--custom--border--radius--md)"
        }
      },
      "core/list": {
        "spacing": {
          "padding": {
            "left": "var(--wp--preset--spacing--50)"
          }
        }
      },
      "core/separator": {
        "color": {
          "text": "var(--wp--preset--color--neutral-200)"
        },
        "border": {
          "color": "currentColor",
          "style": "solid",
          "width": "0 0 1px 0"
        }
      },
      "core/button": {
        "variations": {
          "outline": {
            "border": {
              "color": "var(--wp--preset--color--primary)",
              "width": "2px",
              "style": "solid"
            },
            "color": {
              "background": "transparent",
              "text": "var(--wp--preset--color--primary)"
            }
          }
        }
      }
    }
  },
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" }
  ],
  "customTemplates": [
    { "name": "page",    "title": "Page",         "postTypes": ["page"] },
    { "name": "single",  "title": "Single Post",  "postTypes": ["post"] },
    { "name": "archive", "title": "Archive",      "postTypes": ["post"] },
    { "name": "404",     "title": "404 Not Found" }
  ]
}
