{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "custom": {
      "breakpoints": {
        "mobile": "640px",
        "tablet": "768px",
        "desktop": "1024px",
        "wide": "1280px"
      },
      "border": {
        "radius": {
          "sm": "4px",
          "md": "8px",
          "lg": "12px",
          "full": "9999px"
        }
      },
      "shadow": {
        "sm": "0 1px 2px 0 rgb(0 0 0 / 0.05)",
        "md": "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)",
        "lg": "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)"
      },
      "transition": {
        "fast": "150ms",
        "normal": "250ms",
        "slow": "400ms"
      },
      "easing": {
        "default": "cubic-bezier(0.4, 0, 0.2, 1)",
        "bounce": "cubic-bezier(0.68, -0.55, 0.265, 1.55)"
      }
    },
    "layout": {
      "contentSize": "800px",
      "wideSize": "1200px"
    },
    "color": {
      "palette": [
        {
          "slug": "primary",
          "color": "#0f172a",
          "name": "Primary"
        },
        {
          "slug": "secondary",
          "color": "#334155",
          "name": "Secondary"
        },
        {
          "slug": "accent",
          "color": "#f59e0b",
          "name": "Accent"
        },
        {
          "slug": "base",
          "color": "#ffffff",
          "name": "Base"
        },
        {
          "slug": "contrast",
          "color": "#f8fafc",
          "name": "Contrast"
        },
        {
          "slug": "surface",
          "color": "#0f172a",
          "name": "Surface"
        },
        {
          "slug": "neutral-50",
          "color": "#fafafa",
          "name": "Neutral 50"
        },
        {
          "slug": "neutral-100",
          "color": "#f5f5f5",
          "name": "Neutral 100"
        },
        {
          "slug": "neutral-200",
          "color": "#e5e5e5",
          "name": "Neutral 200"
        },
        {
          "slug": "neutral-300",
          "color": "#d4d4d4",
          "name": "Neutral 300"
        },
        {
          "slug": "neutral-400",
          "color": "#a3a3a3",
          "name": "Neutral 400"
        },
        {
          "slug": "neutral-500",
          "color": "#737373",
          "name": "Neutral 500"
        },
        {
          "slug": "neutral-600",
          "color": "#525252",
          "name": "Neutral 600"
        },
        {
          "slug": "neutral-700",
          "color": "#404040",
          "name": "Neutral 700"
        },
        {
          "slug": "neutral-800",
          "color": "#262626",
          "name": "Neutral 800"
        },
        {
          "slug": "neutral-900",
          "color": "#171717",
          "name": "Neutral 900"
        }
      ],
      "gradients": [
        {
          "slug": "primary-gradient",
          "gradient": "linear-gradient(135deg, var(--wp--preset--color--primary) 0%, var(--wp--preset--color--secondary) 100%)",
          "name": "Primary Gradient"
        },
        {
          "slug": "accent-gradient",
          "gradient": "linear-gradient(135deg, var(--wp--preset--color--accent) 0%, #ea580c 100%)",
          "name": "Accent Gradient"
        },
        {
          "slug": "hero-gradient",
          "gradient": "linear-gradient(180deg, var(--wp--preset--color--primary) 0%, #1e293b 100%)",
          "name": "Hero Gradient"
        },
        {
          "slug": "subtle-gradient",
          "gradient": "linear-gradient(180deg, var(--wp--preset--color--contrast) 0%, var(--wp--preset--color--base) 100%)",
          "name": "Subtle Gradient"
        },
        {
          "slug": "glass-gradient",
          "gradient": "linear-gradient(135deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0.05) 100%)",
          "name": "Glass Gradient"
        },
        {
          "slug": "warm-gradient",
          "gradient": "linear-gradient(135deg, #fef3c7 0%, #fde68a 100%)",
          "name": "Warm Gradient"
        },
        {
          "slug": "cool-gradient",
          "gradient": "linear-gradient(135deg, #e0f2fe 0%, #bae6fd 100%)",
          "name": "Cool Gradient"
        }
      ],
      "customGradient": true
    },
    "typography": {
      "fontFamilies": [
        {
          "slug": "heading",
          "name": "Heading (DM Serif Display)",
          "fontFamily": "'DM Serif Display', Georgia, serif",
          "fontFace": [
            {
              "fontFamily": "DM Serif Display",
              "fontStyle": "normal",
              "fontWeight": "400",
              "src": ["https://fonts.gstatic.com/s/dmserifdisplay/v17/-nFnOHM81r4j6k0gjAW3mujVU2B2K_c.ttf"]
            }
          ]
        },
        {
          "slug": "body",
          "name": "Body (Inter)",
          "fontFamily": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
          "fontFace": [
            {
              "fontFamily": "Inter",
              "fontStyle": "normal",
              "fontWeight": "400",
              "src": ["https://fonts.gstatic.com/s/inter/v20/UcCO3FwrK3iLTeHuS_nVMrMxCp50SjIw2boKoduKmMEVuLyfMZg.ttf"]
            },
            {
              "fontFamily": "Inter",
              "fontStyle": "normal",
              "fontWeight": "500",
              "src": ["https://fonts.gstatic.com/s/inter/v20/UcCO3FwrK3iLTeHuS_nVMrMxCp50SjIw2boKoduKmMEVuI6fMZg.ttf"]
            },
            {
              "fontFamily": "Inter",
              "fontStyle": "normal",
              "fontWeight": "600",
              "src": ["https://fonts.gstatic.com/s/inter/v20/UcCO3FwrK3iLTeHuS_nVMrMxCp50SjIw2boKoduKmMEVuGKYMZg.ttf"]
            },
            {
              "fontFamily": "Inter",
              "fontStyle": "normal",
              "fontWeight": "700",
              "src": ["https://fonts.gstatic.com/s/inter/v20/UcCO3FwrK3iLTeHuS_nVMrMxCp50SjIw2boKoduKmMEVuFuYMZg.ttf"]
            }
          ]
        },
        {
          "slug": "system",
          "name": "System Font",
          "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen-Sans, Ubuntu, Cantarell, 'Helvetica Neue', sans-serif"
        },
        {
          "slug": "mono",
          "name": "Monospace",
          "fontFamily": "'JetBrains Mono', Menlo, Monaco, Consolas, 'Courier New', monospace"
        }
      ],
      "fontSizes": [
        {
          "slug": "small",
          "size": "0.875rem",
          "name": "Small"
        },
        {
          "slug": "medium",
          "size": "1rem",
          "name": "Medium"
        },
        {
          "slug": "large",
          "size": "1.125rem",
          "name": "Large"
        },
        {
          "slug": "x-large",
          "size": "1.25rem",
          "name": "X Large"
        },
        {
          "slug": "xx-large",
          "size": "1.5rem",
          "name": "XX Large"
        },
        {
          "slug": "h1",
          "size": "3rem",
          "name": "H1"
        },
        {
          "slug": "h2",
          "size": "2.25rem",
          "name": "H2"
        },
        {
          "slug": "h3",
          "size": "1.75rem",
          "name": "H3"
        },
        {
          "slug": "h4",
          "size": "1.375rem",
          "name": "H4"
        },
        {
          "slug": "h5",
          "size": "1.125rem",
          "name": "H5"
        },
        {
          "slug": "h6",
          "size": "1rem",
          "name": "H6"
        }
      ],
      "lineHeight": true,
      "letterSpacing": true
    },
    "spacing": {
      "spacingScale": {
        "operator": "*",
        "increment": 1.5,
        "steps": 7,
        "mediumStep": 1.5,
        "unit": "rem"
      },
      "spacingSizes": [
        {
          "slug": "10",
          "size": "0.25rem",
          "name": "1"
        },
        {
          "slug": "20",
          "size": "0.5rem",
          "name": "2"
        },
        {
          "slug": "30",
          "size": "0.75rem",
          "name": "3"
        },
        {
          "slug": "40",
          "size": "1rem",
          "name": "4"
        },
        {
          "slug": "50",
          "size": "1.5rem",
          "name": "5"
        },
        {
          "slug": "60",
          "size": "2rem",
          "name": "6"
        },
        {
          "slug": "70",
          "size": "3rem",
          "name": "7"
        },
        {
          "slug": "80",
          "size": "4rem",
          "name": "8"
        },
        {
          "slug": "90",
          "size": "6rem",
          "name": "9"
        },
        {
          "slug": "100",
          "size": "8rem",
          "name": "10"
        }
      ],
      "units": [
        "%",
        "px",
        "em",
        "rem",
        "vh",
        "vw"
      ],
      "padding": true,
      "margin": true
    },
    "border": {
      "radius": true,
      "color": true,
      "style": true,
      "width": true
    },
    "shadow": {
      "presets": [
        {
          "slug": "sm",
          "shadow": "0 1px 2px 0 rgb(0 0 0 / 0.05)"
        },
        {
          "slug": "md",
          "shadow": "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)"
        },
        {
          "slug": "lg",
          "shadow": "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)"
        },
        {
          "slug": "soft",
          "shadow": "0 2px 15px -3px rgba(0, 0, 0, 0.07), 0 10px 20px -2px rgba(0, 0, 0, 0.04)"
        },
        {
          "slug": "elevated",
          "shadow": "0 10px 40px -10px rgba(0, 0, 0, 0.15), 0 4px 6px -4px rgba(0, 0, 0, 0.05)"
        },
        {
          "slug": "card",
          "shadow": "0 1px 3px rgba(0, 0, 0, 0.04), 0 6px 16px rgba(0, 0, 0, 0.06)"
        },
        {
          "slug": "glow",
          "shadow": "0 0 20px rgba(245, 158, 11, 0.3)"
        },
        {
          "slug": "inner-glow",
          "shadow": "inset 0 1px 0 rgba(255, 255, 255, 0.1)"
        }
      ]
    },
    "blocks": {
      "core/button": {
        "color": {
          "background": true,
          "text": true
        },
        "border": {
          "radius": true
        }
      },
      "core/image": {
        "border": {
          "radius": true
        }
      },
      "core/quote": {
        "border": {
          "color": true,
          "radius": true,
          "style": true,
          "width": true
        }
      }
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--base)",
      "text": "var(--wp--preset--color--primary)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body)",
      "fontSize": "var(--wp--preset--font-size--medium)",
      "lineHeight": "1.6",
      "letterSpacing": "0"
    },
    "spacing": {
      "blockGap": "var(--wp--preset--spacing--50)"
    },
    "elements": {
      "link": {
        "color": {
          "text": "var(--wp--preset--color--accent)"
        },
        "typography": {
          "textDecoration": "none"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--primary)"
          },
          "typography": {
            "textDecoration": "underline"
          }
        },
        ":focus": {
          "typography": {
            "textDecoration": "underline dotted"
          }
        }
      },
      "h1": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontSize": "var(--wp--preset--font-size--h1)",
          "fontWeight": "400",
          "lineHeight": "1.1",
          "letterSpacing": "-0.02em"
        },
        "spacing": {
          "margin": {
            "top": "0",
            "bottom": "var(--wp--preset--spacing--50)"
          }
        }
      },
      "h2": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontSize": "var(--wp--preset--font-size--h2)",
          "fontWeight": "400",
          "lineHeight": "1.2",
          "letterSpacing": "-0.02em"
        },
        "spacing": {
          "margin": {
            "top": "0",
            "bottom": "var(--wp--preset--spacing--40)"
          }
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontSize": "var(--wp--preset--font-size--h3)",
          "fontWeight": "400",
          "lineHeight": "1.3",
          "letterSpacing": "-0.01em"
        },
        "spacing": {
          "margin": {
            "top": "0",
            "bottom": "var(--wp--preset--spacing--40)"
          }
        }
      },
      "h4": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--body)",
          "fontSize": "var(--wp--preset--font-size--h4)",
          "fontWeight": "600",
          "lineHeight": "1.4",
          "letterSpacing": "-0.01em"
        },
        "spacing": {
          "margin": {
            "top": "0",
            "bottom": "var(--wp--preset--spacing--30)"
          }
        }
      },
      "h5": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--body)",
          "fontSize": "var(--wp--preset--font-size--h5)",
          "fontWeight": "600",
          "lineHeight": "1.4"
        },
        "spacing": {
          "margin": {
            "top": "0",
            "bottom": "var(--wp--preset--spacing--30)"
          }
        }
      },
      "h6": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--body)",
          "fontSize": "var(--wp--preset--font-size--h6)",
          "fontWeight": "600",
          "lineHeight": "1.5"
        },
        "spacing": {
          "margin": {
            "top": "0",
            "bottom": "var(--wp--preset--spacing--30)"
          }
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--base)"
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--body)",
          "fontWeight": "600",
          "letterSpacing": "0.02em"
        },
        "border": {
          "radius": "var(--wp--custom--border--radius--md)"
        },
        "shadow": "var(--wp--preset--shadow--sm)",
        "spacing": {
          "padding": {
            "top": "var(--wp--preset--spacing--30)",
            "right": "var(--wp--preset--spacing--50)",
            "bottom": "var(--wp--preset--spacing--30)",
            "left": "var(--wp--preset--spacing--50)"
          }
        },
        ":hover": {
          "color": {
            "background": "var(--wp--preset--color--secondary)"
          },
          "shadow": "var(--wp--preset--shadow--md)"
        },
        ":focus": {
          "shadow": "0 0 0 3px rgba(245, 158, 11, 0.3)"
        },
        ":active": {
          "shadow": "var(--wp--preset--shadow--sm)"
        }
      },
      "caption": {
        "color": {
          "text": "var(--wp--preset--color--neutral-500)"
        },
        "typography": {
          "fontSize": "var(--wp--preset--font-size--small)"
        }
      },
      "cite": {
        "typography": {
          "fontStyle": "normal",
          "fontWeight": "500"
        }
      }
    },
    "blocks": {
      "core/quote": {
        "border": {
          "color": "var(--wp--preset--color--neutral-300)",
          "style": "solid",
          "width": "0 0 0 4px"
        },
        "spacing": {
          "padding": {
            "left": "var(--wp--preset--spacing--50)"
          }
        },
        "typography": {
          "fontStyle": "italic"
        }
      },
      "core/code": {
        "color": {
          "background": "var(--wp--preset--color--neutral-100)",
          "text": "var(--wp--preset--color--neutral-800)"
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--mono)",
          "fontSize": "var(--wp--preset--font-size--small)"
        },
        "spacing": {
          "padding": {
            "top": "var(--wp--preset--spacing--40)",
            "right": "var(--wp--preset--spacing--40)",
            "bottom": "var(--wp--preset--spacing--40)",
            "left": "var(--wp--preset--spacing--40)"
          }
        },
        "border": {
          "radius": "var(--wp--custom--border--radius--md)"
        }
      },
      "core/list": {
        "spacing": {
          "padding": {
            "left": "var(--wp--preset--spacing--50)"
          }
        }
      },
      "core/separator": {
        "color": {
          "text": "var(--wp--preset--color--neutral-200)"
        },
        "border": {
          "color": "currentColor",
          "style": "solid",
          "width": "0 0 1px 0"
        }
      },
      "core/button": {
        "variations": {
          "outline": {
            "border": {
              "color": "var(--wp--preset--color--primary)",
              "width": "2px",
              "style": "solid"
            },
            "color": {
              "background": "transparent",
              "text": "var(--wp--preset--color--primary)"
            }
          }
        }
      }
    }
  },
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    }
  ],
  "customTemplates": [
    {
      "name": "page",
      "title": "Page",
      "postTypes": [
        "page"
      ]
    },
    {
      "name": "page-no-sidebar",
      "title": "Page (No Sidebar)",
      "postTypes": [
        "page"
      ]
    },
    {
      "name": "single",
      "title": "Single Post",
      "postTypes": [
        "post"
      ]
    },
    {
      "name": "archive",
      "title": "Archive",
      "postTypes": [
        "post"
      ]
    },
    {
      "name": "archive-product",
      "title": "Product Archive",
      "postTypes": [
        "product"
      ]
    },
    {
      "name": "single-product",
      "title": "Single Product",
      "postTypes": [
        "product"
      ]
    },
    {
      "name": "404",
      "title": "404 Not Found"
    }
  ]
}